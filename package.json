{
  "name": "grafana-timestream-datasource",
  "version": "2.13.0",
  "description": "Load data timestream in grafana",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e": "playwright test",
    "lint": "eslint --cache .",
    "lint:fix": "yarn run lint --fix && prettier --write --list-different .",
    "server": "docker compose up --build",
    "sign": "npx --yes --ignore-scripts --package @grafana/sign-plugin@3.2.2 sign-plugin",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "test:coverage": "jest --coverage",
    "test:coverage:changes": "jest --coverage --changedSince=origin/main",
    "typecheck": "tsc --noEmit"
  },
  "repository": "github:grafana/timestream-datasource",
  "author": "Grafana Labs <team@grafana.com> (https://grafana.com)",
  "license": "Apache-2.0",
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "13.1.1",
    "@grafana/plugin-ui": "0.17.3",
    "@grafana/runtime": "13.1.1",
    "@grafana/schema": "13.1.1",
    "@grafana/ui": "13.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.4",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "9.39.5",
    "@grafana/aws-sdk": "0.12.0",
    "@grafana/eslint-config": "9.0.0",
    "@grafana/plugin-e2e": "3.10.0",
    "@grafana/tsconfig": "2.2.0",
    "@openfeature/web-sdk": "1.9.0",
    "@playwright/test": "1.61.1",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.46",
    "@swc/helpers": "0.5.23",
    "@swc/jest": "0.2.39",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.3",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@types/semver": "7.7.1",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "copy-webpack-plugin": "14.0.0",
    "cspell": "10.0.1",
    "css-loader": "7.1.4",
    "dotenv": "17.4.2",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-webpack-plugin": "5.0.3",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "glob": "13.0.6",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "5.0.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "prettier": "3.9.5",
    "react-select-event": "5.5.1",
    "replace-in-file-webpack-plugin": "1.0.6",
    "sass": "1.101.3",
    "sass-loader": "17.0.0",
    "semver": "7.8.5",
    "style-loader": "4.0.0",
    "swc-loader": "0.2.7",
    "terser-webpack-plugin": "5.6.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "webpack": "5.108.4",
    "webpack-cli": "7.2.1",
    "webpack-livereload-plugin": "3.0.2",
    "webpack-subresource-integrity": "5.1.0",
    "webpack-virtual-modules": "0.6.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.17.1",
  "resolutions": {
    "node-gyp": "13.0.1"
  }
}
