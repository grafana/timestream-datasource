{
  "name": "grafana-timestream-datasource",
  "version": "2.13.0",
  "description": "Load data timestream in grafana",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e": "playwright test",
    "lint": "eslint --cache .",
    "lint:fix": "yarn run lint --fix && prettier --write --list-different .",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "test:coverage": "jest --coverage",
    "test:coverage:changes": "jest --coverage --changedSince=origin/main",
    "typecheck": "tsc --noEmit"
  },
  "repository": "github:grafana/timestream-datasource",
  "author": "Grafana Labs <team@grafana.com> (https://grafana.com)",
  "license": "Apache-2.0",
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "^12.1.0",
    "@grafana/plugin-ui": "^0.13.0",
    "@grafana/runtime": "^12.1.0",
    "@grafana/schema": "^12.1.0",
    "@grafana/ui": "^12.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.22.0",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.2",
    "@babel/core": "7.29.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@grafana/aws-sdk": "0.10.2",
    "@grafana/eslint-config": "9.0.0",
    "@grafana/plugin-e2e": "3.6.1",
    "@grafana/tsconfig": "2.0.1",
    "@openfeature/web-sdk": "1.8.0",
    "@playwright/test": "1.59.1",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.30",
    "@swc/helpers": "0.5.21",
    "@swc/jest": "0.2.39",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.2",
    "@types/semver": "7.7.1",
    "@types/testing-library__jest-dom": "5.14.9",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "copy-webpack-plugin": "14.0.0",
    "cspell": "10.0.0",
    "css-loader": "7.1.4",
    "dotenv": "17.4.2",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-deprecation": "3.0.0",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-webpack-plugin": "5.0.3",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "glob": "13.0.6",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "5.0.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "prettier": "3.8.3",
    "react-select-event": "5.5.1",
    "replace-in-file-webpack-plugin": "1.0.6",
    "sass": "1.99.0",
    "sass-loader": "16.0.7",
    "semver": "7.7.4",
    "style-loader": "4.0.0",
    "swc-loader": "0.2.7",
    "terser-webpack-plugin": "5.4.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2",
    "webpack-livereload-plugin": "3.0.2",
    "webpack-subresource-integrity": "5.1.0",
    "webpack-virtual-modules": "0.6.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.14.1"
}
