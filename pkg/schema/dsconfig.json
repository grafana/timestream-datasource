{
  "$schema": "https://raw.githubusercontent.com/grafana/dsconfig/refs/heads/main/dsconfig/schema.json",
  "schemaVersion": "v1",
  "pluginType": "grafana-timestream-datasource",
  "pluginName": "Amazon Timestream",
  "docURL": "https://grafana.com/grafana/plugins/grafana-timestream-datasource/",
  "instructions": [
    {
      "msg": "Uses AWS authentication only. Set the Authentication Provider (authType) to one of: AWS SDK Default (default), Access & secret key (keys), Credentials file (credentials), Grafana Assume Role (grafana_assume_role), or EC2 IAM Role (ec2_iam_role) — ask which. But never ask for credentials themselves (access key, secret key, session token). Those should be entered in the UI.",
      "tags": ["llm"]
    }
  ],
  "fields": [
    {
      "id": "jsonData.authType",
      "key": "authType",
      "label": "Authentication Provider",
      "description": "AWS authentication method.",
      "valueType": "string",
      "target": "jsonData",
      "defaultValue": "default"
    },
    {
      "id": "jsonData.defaultRegion",
      "key": "defaultRegion",
      "label": "Default Region",
      "description": "AWS region for Timestream queries.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.region",
      "key": "region",
      "label": "Region",
      "description": "AWS region.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.assumeRoleARN",
      "key": "assumeRoleARN",
      "label": "Assume Role ARN",
      "description": "ARN of the IAM role to assume.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.externalId",
      "key": "externalId",
      "label": "External ID",
      "description": "External ID for cross-account role assumption.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.proxyType",
      "key": "proxyType",
      "label": "Proxy Type",
      "description": "Proxy type used to connect to AWS.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.proxyUrl",
      "key": "proxyUrl",
      "label": "Proxy URL",
      "description": "URL of the proxy used to connect to AWS.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.proxyUsername",
      "key": "proxyUsername",
      "label": "Proxy Username",
      "description": "Username for the proxy used to connect to AWS.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.profile",
      "key": "profile",
      "label": "Credentials Profile Name",
      "description": "AWS credentials profile name.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.endpoint",
      "key": "endpoint",
      "label": "Endpoint",
      "description": "Optional custom Timestream endpoint.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.defaultDatabase",
      "key": "defaultDatabase",
      "label": "Default Database",
      "description": "Default Timestream database.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.defaultTable",
      "key": "defaultTable",
      "label": "Default Table",
      "description": "Default Timestream table.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "jsonData.defaultMeasure",
      "key": "defaultMeasure",
      "label": "Default Measure",
      "description": "Default Timestream measure.",
      "valueType": "string",
      "target": "jsonData"
    },
    {
      "id": "secureJsonData.accessKey",
      "key": "accessKey",
      "label": "Access Key ID",
      "description": "AWS access key ID.",
      "valueType": "string",
      "role": "auth.aws.accessKeyId",
      "target": "secureJsonData"
    },
    {
      "id": "secureJsonData.secretKey",
      "key": "secretKey",
      "label": "Secret Access Key",
      "description": "AWS secret access key.",
      "valueType": "string",
      "role": "auth.aws.secretAccessKey",
      "target": "secureJsonData"
    },
    {
      "id": "secureJsonData.sessionToken",
      "key": "sessionToken",
      "label": "Session Token",
      "description": "AWS temporary session token.",
      "valueType": "string",
      "role": "auth.aws.sessionToken",
      "target": "secureJsonData"
    }
  ],
  "groups": [
    {
      "id": "auth",
      "title": "Authentication",
      "fieldRefs": [
        "jsonData.authType",
        "jsonData.defaultRegion",
        "jsonData.region",
        "jsonData.profile",
        "jsonData.assumeRoleARN",
        "jsonData.externalId",
        "jsonData.endpoint",
        "jsonData.proxyType",
        "jsonData.proxyUrl",
        "jsonData.proxyUsername",
        "secureJsonData.accessKey",
        "secureJsonData.secretKey",
        "secureJsonData.sessionToken"
      ]
    },
    {
      "id": "timestream-details",
      "title": "Timestream details",
      "fieldRefs": ["jsonData.defaultDatabase", "jsonData.defaultTable", "jsonData.defaultMeasure"]
    }
  ]
}
